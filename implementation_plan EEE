Create a migration script to set up the `electronic_products` table:
```sql
CREATE TABLE electronic_products (
    id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name          TEXT NOT NULL,
    price         TEXT NOT NULL, -- Flexible formatting (e.g., "15,500" or "ZMW 15,500")
    image_content TEXT NOT NULL, -- Base64 Data URL representation of uploaded image
    created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- Index to optimize querying active products
CREATE INDEX idx_electronic_products_created_at ON electronic_products(created_at DESC);
```

